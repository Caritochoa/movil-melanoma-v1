{
  "expo": {
    "name": "movil-melanoma-v1",
    "slug": "movil-melanoma-v1",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "movilmelanomav1",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}